{
  "name": "rhospital-release-publisher",
  "version": "0.1.0",
  "private": true,
  "description": "RHospital Release Console for local Docker release operations.",
  "scripts": {
    "start": "node server.js",
    "service:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-startup-task.ps1",
    "service:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/status-startup-task.ps1",
    "service:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-startup-task.ps1",
    "test": "node --test test/*.test.js"
  },
  "engines": {
    "node": ">=18"
  }
}
